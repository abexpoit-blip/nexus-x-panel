# NexusX Backend Configuration
# Copy this to .env on your VPS and fill in real values

# Server
PORT=4000
NODE_ENV=production

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Database
DB_PATH=./data/nexus.db

# CORS — your frontend origin
CORS_ORIGIN=https://yourdomain.com

# Default admin (created on first DB init)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ============================================================
# Seven1Tel Provider — axios scraper for /ints panel
# ============================================================
SEVEN1TEL_ENABLED=false
SEVEN1TEL_BASE_URL=http://94.23.120.156/ints
SEVEN1TEL_USERNAME=
SEVEN1TEL_PASSWORD=
SEVEN1TEL_OTP_INTERVAL=4

# Fake OTP broadcaster defaults (off by default)
FAKE_OTP_ENABLED=false
FAKE_OTP_MIN_SEC=15
FAKE_OTP_MAX_SEC=90
FAKE_OTP_BURST=1

# ============================================================
# IMS Bot #2 — second imssms.org account (independent session)
# ============================================================
IMS2_ENABLED=false
IMS2_BASE_URL=https://www.imssms.org
IMS2_USERNAME=Nexusx0
IMS2_PASSWORD=Nexusx0
IMS2_OTP_INTERVAL=20
